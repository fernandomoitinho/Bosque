# ── Bosque Reservas — environment ───────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

# Server
PORT=3000
# Public base URL (used in emails / quote links). No trailing slash.
BASE_URL=http://localhost:3000

# Admin login
# Session signing secret — any long random string.
SESSION_SECRET=change-me-to-a-long-random-string
# bcrypt hash of the admin password. Generate with:
#   node scripts/hash-password.js "your-password"
ADMIN_PASSWORD_HASH=

# ── Gmail (Nodemailer) ───────────────────────────────────────────────────────
# The mailbox emails are sent from. Use a Google "App Password" (NOT your normal
# password): https://myaccount.google.com/apppasswords (requires 2FA enabled).
GMAIL_USER=fernandomoitinho@gmail.com
GMAIL_APP_PASSWORD=
# Where new-request alerts go (defaults to GMAIL_USER if empty).
OWNER_NOTIFY_EMAIL=fernandomoitinho@gmail.com

# ── Google Calendar (googleapis OAuth2) ──────────────────────────────────────
# Create an OAuth client (type "Desktop app") in Google Cloud Console and enable
# the Google Calendar API. Then run `npm run token` once to obtain a refresh
# token (see README). Use a dedicated calendar "Bosque Reservas" and put its ID
# below (Calendar settings → "Integrate calendar" → Calendar ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Optional: set to "1" to run without Calendar/Gmail (logs instead of sending).
# Useful for local UI development before credentials are wired in.
DRY_RUN=0
